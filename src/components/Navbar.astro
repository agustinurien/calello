---
import { FaFacebook, FaFacebookF, FaInstagram, FaLinkedinIn, FaWhatsapp } from "react-icons/fa";
---

<nav>
    <div class="left">
        <div class="contenedorLogo">
            <img src=""/>
        </div>
        <h2>Dr. Santiago Calello</h2>
    </div>
    <div class="right">
        <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/">Quien soy</a></li>
            <li><a href="/">Consultorios</a></li>
            <li><a href="/">Pre Quirurgico</a></li>
            <li><a href="/">Patologias Ambulatorias</a></li>
        </ul>
        <div class="socialContainer">
            <div class="social">
                <a href=""><FaInstagram /></a>
                <a href=""><FaFacebookF /></a>
                <a href=""><FaLinkedinIn /></a>
            </div>
            <div class="wpp">
                <a href="" class="wppIcon"><FaWhatsapp/></a>
                <a href="" class="contactar">CONTACTAR</a>
            </div>
        </div>
    </div>
</nav>

<style>
    nav{
        position: fixed;
        top: 0;
        left: 0;
        height: 90px;
        background-color: #1f3147;
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        z-index: 1000;
        padding: 0px 5%;
        box-sizing: border-box;
    }
    .left{
        
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .left .contenedorLogo{
        background-color: rgb(0, 255, 0);
        height: 70px;
        width: 70px;
    }
    .left h2{
        margin: 0px;
        color: white;
    }
    .right{
        
        display: flex;
        gap: 20px;
    }
    .right ul{
        display: flex;
        gap: 10px;
        margin: 0px;
    }
    .right ul li{
    
        list-style: none;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .right ul li a{
        color: white;
        text-decoration: none;
    }
    .socialContainer{
        display: flex;
        gap: 10px;
    }
    .socialContainer .social{
        
        display: flex;
        gap: 5px;
    }
    .socialContainer .social a{
        background-color: rgb(255, 255, 255);
        color: #1f3147;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 20px;
    }
    .wpp{
        display:flex;
        align-items: center;
        height: 30px;
        
    }
    .wpp .contactar{
        background-color: rgb(255, 255, 255);
        color: #1f3147;
        border-radius: 20px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 0.8rem;
        padding: 0px 10px;
        height: 100%;
        text-decoration: none;
    }
    .wpp .wppIcon{
        background-color: rgb(255, 255, 255);
        color: #1f3147;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 20px;
    }

</style>